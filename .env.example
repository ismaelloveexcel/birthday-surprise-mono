# ============================================================
# Birthday Surprise — Environment Variables
# Copy to .env (or .env.local for Next.js) and fill in values.
# NEVER commit the filled-in file — it is in .gitignore.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=              # e.g. https://abcdef.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # anon/public key — safe for client
EXPO_PUBLIC_SUPABASE_URL=              # same value as NEXT_PUBLIC_SUPABASE_URL
EXPO_PUBLIC_SUPABASE_ANON_KEY=         # same value as NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=             # server-side ONLY — never expose to client or mobile

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=                     # REQUIRED — server-side only, app throws on missing

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                     # server-side ONLY — never expose
STRIPE_WEBHOOK_SECRET=                 # from Stripe dashboard → Webhooks
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # public key — safe for client
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # same as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY

# ── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=                  # e.g. https://yourdomain.com (no trailing slash)
EXPO_PUBLIC_WEB_BASE_URL=              # same value — used by mobile for deep links & API calls

# ── Optional: Branch.io deferred deep links ───────────────────
BRANCH_KEY=                            # leave empty to use URL scheme fallback only
